<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Template. install-agent.sh substitutes __PROJECT_DIR__ and installs this to
     ~/Library/LaunchAgents. Runs a scan every 4h locally (and once at load). -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.meatgrinder.crimescan</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_DIR__/scripts/scan-once.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>__PROJECT_DIR__</string>

  <key>StartInterval</key>
  <integer>14400</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/data/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/data/logs/launchd.err.log</string>

  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
