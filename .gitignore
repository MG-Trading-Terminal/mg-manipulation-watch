# Python
__pycache__/
*.pyc
.venv/
.local-venv/

# Node / Vite
node_modules/

# Generated site (rebuilt by CI; not source)
dist/

# Generated data module (baked from data/candidates/index.json by build-site-data.mjs)
src/data/generated.ts

# Generated current snapshot (4MB+, regenerated each scan). The committed base
# summary is data/history/_scans.jsonl; full snapshots are in data/snapshots/.
data/candidates/index.json

# Local runtime logs (data/history/ IS the base — keep it tracked)
data/logs/

# Per-scan full snapshots — the local base, but 4MB+ each. Kept on disk, out of
# git; data/history/_scans.jsonl is the lightweight committed summary.
data/snapshots/

# Bulk enrichment cache (rebuilt by detector.enrich; not source)
data/enrich/

# OS / editor
.DS_Store
*.swp

# Design handoff reference (large; not shipped). Comment out to version it.
_design-ref/
